# Shanti Care — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Cloudflare Workers API (production backend)
VITE_API_URL=https://shanti-care-api.eduportal.workers.dev

# Demo mode — set to false for production (all data goes to real API + D1 database)
VITE_DEMO_MODE=false

# Optional: Hospital LAN server for local-first sync
# VITE_LAN_URL=http://192.168.1.100:8787

# Optional: ABDM sandbox credentials
# VITE_ABDM_CLIENT_ID=your_client_id
# VITE_ABDM_CLIENT_SECRET=your_secret

# Optional: Hospital Facility Registry ID (for ABDM production)
# VITE_HFR_ID=your_hfr_id
